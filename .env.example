# Supabase — AtomicMoriarty's Project (schema: meu_lutador)
SUPABASE_URL=https://nozthsissdwkfwtogmdu.supabase.co

# Service-role secret key (Settings > API > service_role).
# Needed because direct Postgres ports are blocked here, so we load over the
# REST API. Keep this OUT of git (.env is gitignored). RLS is bypassed by this
# key — only used for the one-off ingestion, never shipped to the frontend.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
